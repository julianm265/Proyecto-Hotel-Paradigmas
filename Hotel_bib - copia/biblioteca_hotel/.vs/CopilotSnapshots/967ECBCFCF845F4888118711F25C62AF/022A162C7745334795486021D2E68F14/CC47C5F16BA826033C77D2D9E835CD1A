        /// <summary>
        /// Test 5: Verificar bloqueo por múltiples intentos fallidos
        /// </summary>
        public static bool Test_Autenticador_BloqueoPorIntentos()
        {
            Console.WriteLine("Test: Autenticador - Bloqueo por Intentos Fallidos");
            var autenticador = new Autenticador();

            // Hacer 3 intentos fallidos
            for (int i = 0; i < 3; i++)
            {
                autenticador.verificar_acceso("recepcion", "123");
            }

            // El 4to intento debería ser bloqueado
            bool resultado = autenticador.verificar_acceso("recepcion", "password123");

            if (!resultado)
            {
                Console.WriteLine("✓ PASÓ: Usuario bloqueado después de múltiples intentos\n");
                return true;
            }

            Console.WriteLine("✗ FALLÓ: Usuario debería estar bloqueado\n");
            return false;
        }

