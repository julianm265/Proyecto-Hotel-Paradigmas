        /// <summary>
        /// Test 1: Verificar que ArgumentNullException se lanza con usuario nulo
        /// </summary>
        public static bool Test_Autenticador_UsuarioNulo()
        {
            Console.WriteLine("Test: Autenticador - Usuario Nulo");
            var autenticador = new Autenticador();

            try
            {
                autenticador.verificar_acceso(null, "password123");
                Console.WriteLine("✗ FALLÓ: Debería haber lanzado ArgumentNullException");
                return false;
            }
            catch (ArgumentNullException ex)
            {
                if (ex.ParamName == "usuario")
                {
                    Console.WriteLine("✓ PASÓ: ArgumentNullException lanzada correctamente\n");
                    return true;
                }
                Console.WriteLine("✗ FALLÓ: ParamName incorrecto\n");
                return false;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"✗ FALLÓ: Excepción inesperada: {ex.GetType().Name}\n");
                return false;
            }
        }

