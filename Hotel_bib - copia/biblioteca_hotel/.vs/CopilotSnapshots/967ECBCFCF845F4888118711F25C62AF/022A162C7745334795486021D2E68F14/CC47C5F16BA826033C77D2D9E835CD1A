        // ========== EJECUTOR DE PRUEBAS ==========

        /// <summary>
        /// Ejecuta todas las pruebas y muestra un resumen
        /// </summary>
        public static void EjecutarTodasLasPruebas()
        {
            Console.WriteLine("\n╔══════════════════════════════════════════════════════════╗");
            Console.WriteLine("║     SUITE DE PRUEBAS - ROBUSTEZ DE ERRORES              ║");
            Console.WriteLine("╚══════════════════════════════════════════════════════════╝\n");

            int totalPruebas = 14;
            int pruebaPasadas = 0;

            // Pruebas de Autenticador
            Console.WriteLine("▶ PRUEBAS DE AUTENTICADOR\n");
            if (Test_Autenticador_UsuarioNulo()) pruebaPasadas++;
            if (Test_Autenticador_ContraseñaNula()) pruebaPasadas++;
            if (Test_Autenticador_ContraseñaCorta()) pruebaPasadas++;
            if (Test_Autenticador_AccesoValido()) pruebaPasadas++;
            if (Test_Autenticador_BloqueoPorIntentos()) pruebaPasadas++;
            if (Test_Autenticador_DesbloqueoManual()) pruebaPasadas++;

            // Pruebas de Validador
            Console.WriteLine("▶ PRUEBAS DE VALIDADOR\n");
            if (Test_Validador_PersonaNula()) pruebaPasadas++;
            if (Test_Validador_PersonaIdInvalido()) pruebaPasadas++;
            if (Test_Validador_PersonaTelefonoInvalido()) pruebaPasadas++;
            if (Test_Validador_PersonaValida()) pruebaPasadas++;
            if (Test_Validador_ReservaFechasInvertidas()) pruebaPasadas++;
            if (Test_Validador_ReservaValida()) pruebaPasadas++;
            if (Test_Validador_FacturaVacia()) pruebaPasadas++;
            if (Test_Validador_FacturaValida()) pruebaPasadas++;

            // Resumen
            Console.WriteLine("╔══════════════════════════════════════════════════════════╗");
            Console.WriteLine($"║  RESUMEN: {pruebaPasadas}/{totalPruebas} pruebas PASADAS ({(pruebaPasadas * 100 / totalPruebas)}%)");
            Console.WriteLine("╚══════════════════════════════════════════════════════════╝\n");

            if (pruebaPasadas == totalPruebas)
            {
                Console.WriteLine("✓ TODAS LAS PRUEBAS PASARON EXITOSAMENTE!");
            }
            else
            {
                Console.WriteLine($"✗ {totalPruebas - pruebaPasadas} prueba(s) fallaron.");
            }
        }

        public static void Main(string[] args)
        {
            EjecutarTodasLasPruebas();
