            Console.WriteLine("Caso 3: Persona con teléfono inválido (muy corto)");
            var persona2 = new Huesped("María García", "DNI", "1234567890", "123");
            valido = validador.Advice_ValidarYPersistir(persona2);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 4: Persona válida
            Console.WriteLine("Caso 4: Persona válida");
            var persona3 = new Huesped("Carlos López", "DNI", "1234567890", "3001234567");
            valido = validador.Advice_ValidarYPersistir(persona3);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 5: Cliente válido
