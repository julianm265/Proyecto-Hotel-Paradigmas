    /// <summary>
    /// Ejemplos prácticos de uso de las clases mejoradas Autenticador y Validador
    /// con manejo robusto de errores.
    /// </summary>
    public class EjemplosUsoRobustez
    {
        /// <summary>
        /// Ejemplo 1: Verificación de acceso con Autenticador
        /// Demuestra validaciones de seguridad, bloqueo temporal y intentos fallidos
        /// </summary>
        public static void EjemploAutenticador()
        {
            Console.WriteLine("=== EJEMPLO 1: Autenticador con Manejo de Errores ===\n");

            var autenticador = new Autenticador();

            // Caso 1: Intento con usuario nulo
            Console.WriteLine("Caso 1: Usuario nulo");
            try
            {
                autenticador.verificar_acceso(null, "password123");
            }
            catch (ArgumentNullException ex)
            {
                Console.WriteLine($"✗ Error capturado: {ex.ParamName} - {ex.Message}\n");
            }

            // Caso 2: Contraseña vacía
            Console.WriteLine("Caso 2: Contraseña vacía");
            try
            {
                autenticador.verificar_acceso("admin", "");
            }
            catch (ArgumentException ex)
            {
                Console.WriteLine($"✗ Error capturado: {ex.Message}\n");
            }

            // Caso 3: Contraseña muy corta
            Console.WriteLine("Caso 3: Contraseña demasiado corta");
            bool resultado = autenticador.verificar_acceso("admin", "12345");
            Console.WriteLine($"Resultado: {resultado}\n");

            // Caso 4: Usuario no autorizado
            Console.WriteLine("Caso 4: Usuario no autorizado");
            resultado = autenticador.verificar_acceso("usuariofalso", "password123");
            Console.WriteLine($"Resultado: {resultado}\n");

            // Caso 5: Acceso correcto
            Console.WriteLine("Caso 5: Acceso correcto");
            resultado = autenticador.verificar_acceso("admin", "password123");
            Console.WriteLine($"Resultado: {resultado}\n");

            // Caso 6: Múltiples intentos fallidos (simular bloqueo)
            Console.WriteLine("Caso 6: Simular bloqueo por múltiples intentos");
            for (int i = 1; i <= 4; i++)
            {
                Console.WriteLine($"Intento {i}:");
                resultado = autenticador.verificar_acceso("recepcion", "123");
                Console.WriteLine($"Acceso permitido: {resultado}\n");
            }

            // Caso 7: Verificar intentos fallidos
            Console.WriteLine("Caso 7: Verificar estadísticas");
            int intentos = autenticador.obtener_intentos_fallidos("recepcion");
            Console.WriteLine($"Intentos fallidos para 'recepcion': {intentos}\n");

            // Caso 8: Desbloquear usuario
            Console.WriteLine("Caso 8: Desbloquear usuario manualmente");
            bool desbloqueado = autenticador.desbloquear_usuario("recepcion");
            Console.WriteLine($"Usuario desbloqueado: {desbloqueado}\n");
        }

