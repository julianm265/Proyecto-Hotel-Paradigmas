            Console.WriteLine($"Validación exitosa: {valido}\n");
        }

        /// <summary>
        /// Ejemplo 3: Validación de Reservas con Validador
        /// Demuestra validaciones de fechas y coherencia
        /// </summary>
        public static void EjemploValidadorReserva()
        {
            Console.WriteLine("=== EJEMPLO 3: Validador de Reservas ===\n");

            var validador = new Validador();

            // Crear objetos para las pruebas
            var persona = new Huesped("Roberto Díaz", "DNI", "9876543210", "3107654321");
            var habitacion = new Sencilla(150000, "doble", 1);

            // Caso 1: Reserva con fechas invertidas
            Console.WriteLine("Caso 1: Reserva con fechas invertidas");
            var fechaEntrada = DateTime.Now.AddDays(10);
            var fechaSalida = DateTime.Now.AddDays(5); // Antes que entrada
            var reserva1 = new Reserva(persona, habitacion, fechaEntrada, fechaSalida);
            bool valido = validador.Advice_ValidarYPersistir(reserva1);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 2: Reserva con fecha de entrada en el pasado
            Console.WriteLine("Caso 2: Reserva con fecha de entrada en el pasado");
            fechaEntrada = DateTime.Now.AddDays(-5);
            fechaSalida = DateTime.Now.AddDays(5);
            var reserva2 = new Reserva(persona, habitacion, fechaEntrada, fechaSalida);
            valido = validador.Advice_ValidarYPersistir(reserva2);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 3: Reserva con duración demasiado larga
            Console.WriteLine("Caso 3: Reserva con duración mayor a 30 días");
            fechaEntrada = DateTime.Now.AddDays(2);
            fechaSalida = DateTime.Now.AddDays(35); // 33 días
            var reserva3 = new Reserva(persona, habitacion, fechaEntrada, fechaSalida);
            valido = validador.Advice_ValidarYPersistir(reserva3);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 4: Reserva válida
            Console.WriteLine("Caso 4: Reserva válida");
            fechaEntrada = DateTime.Now.AddDays(2);
            fechaSalida = DateTime.Now.AddDays(7); // 5 días
            var reserva4 = new Reserva(persona, habitacion, fechaEntrada, fechaSalida);
            valido = validador.Advice_ValidarYPersistir(reserva4);
            Console.WriteLine($"Validación exitosa: {valido}\n");
        }

        /// <summary>
        /// Ejemplo 4: Validación de Facturas con Validador
        /// Demuestra validaciones de montos y coherencia
        /// </summary>
        public static void EjemploValidadorFactura()
        {
            Console.WriteLine("=== EJEMPLO 4: Validador de Facturas ===\n");

            var validador = new Validador();
            var persona = new Cliente("Fernando Ruiz", "NIT", "1234567890", "3001234567", 
                                     99999, 0.05f);

            // Caso 1: Factura sin productos (total = 0)
            Console.WriteLine("Caso 1: Factura sin productos");
            var factura1 = new Factura(persona, true);
            bool valido = validador.Advice_ValidarYPersistir(factura1);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 2: Factura con monto válido
            Console.WriteLine("Caso 2: Factura con productos válidos");
            var factura2 = new Factura(persona, true);
            factura2.AgregarProducto(new Licor(35000));
            factura2.AgregarProducto(new Agua(5000));
            valido = validador.Advice_ValidarYPersistir(factura2);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 3: Factura con monto excesivo
            Console.WriteLine("Caso 3: Factura con monto que excede límite");
            var factura3 = new Factura(persona, false);
            // Simular un monto muy grande (en un caso real, se haría diferente)
            for (int i = 0; i < 1000000; i++)
            {
                factura3.AgregarProducto(new Licor(100));
            }
            valido = validador.Advice_ValidarYPersistir(factura3);
            Console.WriteLine($"Validación exitosa: {valido}\n");

            // Caso 4: Obtener estadísticas de validación
            Console.WriteLine("Caso 4: Estadísticas de validación");
            var stats = validador.obtener_estadisticas();
            Console.WriteLine($"Validaciones exitosas: {stats.exitosas}");
            Console.WriteLine($"Validaciones fallidas: {stats.fallidas}");
            Console.WriteLine($"Tasa de éxito: {stats.tasa_exito:F2}%\n");
        }

        /// <summary>
        /// Ejemplo 5: Manejo integrado de errores
        /// Demuestra un flujo completo con captura de excepciones
        /// </summary>
        public static void EjemploManejoProceso()
        {
            Console.WriteLine("=== EJEMPLO 5: Flujo Integrado con Manejo de Errores ===\n");

            var autenticador = new Autenticador();
            var validador = new Validador();

            // Fase 1: Autenticación
            Console.WriteLine("Fase 1: Autenticación de usuario");
            bool acceso = false;
            try
            {
                acceso = autenticador.verificar_acceso("oficina", "securePass123");
                if (acceso)
                    Console.WriteLine("✓ Autenticación exitosa\n");
                else
                    Console.WriteLine("✗ Autenticación fallida\n");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"✗ Error en autenticación: {ex.Message}\n");
            }

            if (!acceso)
                return;

            // Fase 2: Validación de datos
            Console.WriteLine("Fase 2: Validación de datos de entrada");
            try
            {
                var persona = new Huesped("Victoria Santos", "CE", "1234567890", "3001234567");
                bool validoPersona = validador.Advice_ValidarYPersistir(persona);

                if (validoPersona)
                {
                    var habitacion = new Ejecutiva(280000, "queen");
                    var reserva = new Reserva(
                        persona,
                        habitacion,
                        DateTime.Now.AddDays(1),
                        DateTime.Now.AddDays(5)
                    );

                    bool validoReserva = validador.Advice_ValidarYPersistir(reserva);

                    if (validoReserva)
                    {
                        Console.WriteLine("✓ Todos los datos son válidos");
                        Console.WriteLine($"  - Persona: {persona.GetNombre()}");
                        Console.WriteLine($"  - Habitación: {habitacion.GetNumHab()}");
                        Console.WriteLine($"  - Entrada: {reserva.GetFechaEntrada():yyyy-MM-dd}");
                        Console.WriteLine($"  - Salida: {reserva.GetFechaSalida():yyyy-MM-dd}\n");
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"✗ Error en validación: {ex.Message}\n");
            }

            // Fase 3: Resumen
            Console.WriteLine("Fase 3: Resumen final");
            var estadisticas = validador.obtener_estadisticas();
            Console.WriteLine($"Total de validaciones procesadas: {estadisticas.exitosas + estadisticas.fallidas}");
            Console.WriteLine($"Tasa de éxito: {estadisticas.tasa_exito:F2}%");
        }

        /// <summary>
        /// Método principal para ejecutar todos los ejemplos
        /// </summary>
        public static void Main(string[] args)
        {
            try
            {
                Console.OutputEncoding = System.Text.Encoding.UTF8;

                EjemploAutenticador();
                Console.WriteLine("\n" + new string('=', 60) + "\n");

                EjemploValidadorPersona();
                Console.WriteLine("\n" + new string('=', 60) + "\n");

                EjemploValidadorReserva();
                Console.WriteLine("\n" + new string('=', 60) + "\n");

                EjemploValidadorFactura();
                Console.WriteLine("\n" + new string('=', 60) + "\n");

                EjemploManejoProceso();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error inesperado: {ex.Message}");
                Console.WriteLine(ex.StackTrace);
            }
        }
    }
