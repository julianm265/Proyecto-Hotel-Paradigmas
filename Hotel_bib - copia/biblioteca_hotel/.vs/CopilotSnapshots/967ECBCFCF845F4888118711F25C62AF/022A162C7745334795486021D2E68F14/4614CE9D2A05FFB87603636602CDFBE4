using System;
using System.Collections.Generic;

namespace biblioteca_hotel.Aspectos
{
    /// <summary>
    /// Clase Autenticador que implementa un aspecto de seguridad para validar acceso
    /// a operaciones críticas del sistema hotelero.
    /// </summary>
    public class Autenticador
    {
        protected string[] l_usuarios_autorizados;
        protected Dictionary<string, int> intentos_fallidos;
        protected const int MAX_INTENTOS = 3;
        protected const int TIEMPO_BLOQUEO_MINUTOS = 15;
        protected Dictionary<string, DateTime> usuarios_bloqueados;
        protected const int LONGITUD_MINIMA_CONTRASEÑA = 6;

        public Autenticador()
        {
            l_usuarios_autorizados = new string[] { "admin", "recepcion", "oficina" };
            intentos_fallidos = new Dictionary<string, int>();
            usuarios_bloqueados = new Dictionary<string, DateTime>();
        }

        public string pointcut_acceder()
        {
            return "Pointcut: acceder(Recepcion) | acceder(Oficina)";
        }

        /// <summary>
        /// Verifica el acceso del usuario con validaciones robustas de seguridad.
        /// </summary>
        /// <param name="usuario">Nombre de usuario</param>
        /// <param name="contraseña">Contraseña del usuario</param>
        /// <returns>true si el acceso es válido, false en caso contrario</returns>
        /// <exception cref="ArgumentNullException">Cuando usuario o contraseña es nulo</exception>
        /// <exception cref="ArgumentException">Cuando usuario o contraseña está vacío</exception>
        public bool verificar_acceso(string usuario, string contraseña)
        {
            try
            {
                // Validación de parámetros nulos
                if (usuario == null)
                    throw new ArgumentNullException(nameof(usuario), "El nombre de usuario no puede ser nulo");

                if (contraseña == null)
                    throw new ArgumentNullException(nameof(contraseña), "La contraseña no puede ser nula");

                // Validación de parámetros vacíos
                if (string.IsNullOrWhiteSpace(usuario))
                    throw new ArgumentException("El nombre de usuario no puede estar vacío", nameof(usuario));

                if (string.IsNullOrWhiteSpace(contraseña))
                    throw new ArgumentException("La contraseña no puede estar vacía", nameof(contraseña));

                // Trimear espacios en blanco
                usuario = usuario.Trim();
                contraseña = contraseña.Trim();

                // Validación de longitud de contraseña
                if (contraseña.Length < LONGITUD_MINIMA_CONTRASEÑA)
                {
                    registrar_intento_fallido(usuario);
                    denegar_acceso($"Contraseña muy corta. Mínimo {LONGITUD_MINIMA_CONTRASEÑA} caracteres");
                    return false;
                }

                // Verificar si el usuario está bloqueado
                if (usuario_esta_bloqueado(usuario))
                {
                    denegar_acceso($"Usuario '{usuario}' bloqueado temporalmente por demasiados intentos fallidos");
                    return false;
                }

                // Validar que el usuario sea autorizado
                if (!es_usuario_autorizado(usuario))
                {
                    registrar_intento_fallido(usuario);
                    denegar_acceso($"Usuario '{usuario}' no autorizado");
                    return false;
                }

                // Validar contraseña (en un sistema real, se haría hash comparison)
                if (!validar_contraseña(usuario, contraseña))
                {
                    registrar_intento_fallido(usuario);
                    denegar_acceso($"Contraseña incorrecta para usuario '{usuario}'");
                    return false;
                }

                // Reiniciar contador de intentos fallidos en caso de éxito
                if (intentos_fallidos.ContainsKey(usuario))
                    intentos_fallidos[usuario] = 0;

                registrar_acceso_exitoso(usuario);
                return true;
            }
            catch (ArgumentNullException ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error de validación: {ex.Message}");
                throw;
            }
            catch (ArgumentException ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error de argumento: {ex.Message}");
                throw;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error inesperado en verificación de acceso: {ex.Message}");
                denegar_acceso("Error interno en el sistema de autenticación");
                return false;
            }
        }

        /// <summary>
        /// Verifica si el usuario es autorizado
        /// </summary>
        private bool es_usuario_autorizado(string usuario)
        {
            if (l_usuarios_autorizados == null || l_usuarios_autorizados.Length == 0)
            {
                System.Diagnostics.Debug.WriteLine("Advertencia: Lista de usuarios autorizados vacía");
                return false;
            }

            foreach (var user in l_usuarios_autorizados)
            {
                if (!string.IsNullOrEmpty(user) && user.Equals(usuario, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
            return false;
        }

        /// <summary>
        /// Valida la contraseña del usuario (simulado - en producción usar hash)
        /// </summary>
        private bool validar_contraseña(string usuario, string contraseña)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(usuario) || string.IsNullOrWhiteSpace(contraseña))
                    return false;

                // En un sistema real, compararías contra un hash almacenado en una BD
                // Por ahora, aceptamos cualquier contraseña no vacía para usuarios válidos
                // Esto es solo para demostración
                return contraseña.Length >= LONGITUD_MINIMA_CONTRASEÑA;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error al validar contraseña: {ex.Message}");
                return false;
            }
        }

        /// <summary>
        /// Registra un intento fallido y bloquea si excede el máximo
        /// </summary>
        private void registrar_intento_fallido(string usuario)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(usuario))
                    return;

                if (!intentos_fallidos.ContainsKey(usuario))
                    intentos_fallidos[usuario] = 0;

                intentos_fallidos[usuario]++;

                if (intentos_fallidos[usuario] >= MAX_INTENTOS)
                {
                    usuarios_bloqueados[usuario] = DateTime.Now.AddMinutes(TIEMPO_BLOQUEO_MINUTOS);
                    System.Diagnostics.Debug.WriteLine(
                        $"Usuario '{usuario}' bloqueado por {TIEMPO_BLOQUEO_MINUTOS} minutos tras {MAX_INTENTOS} intentos fallidos");
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error registrando intento fallido: {ex.Message}");
            }
        }

        /// <summary>
        /// Verifica si un usuario está temporalmente bloqueado
        /// </summary>
        private bool usuario_esta_bloqueado(string usuario)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(usuario) || !usuarios_bloqueados.ContainsKey(usuario))
                    return false;

                DateTime tiempo_desbloqueo = usuarios_bloqueados[usuario];

                if (DateTime.Now >= tiempo_desbloqueo)
                {
                    usuarios_bloqueados.Remove(usuario);
                    if (intentos_fallidos.ContainsKey(usuario))
                        intentos_fallidos[usuario] = 0;
                    System.Diagnostics.Debug.WriteLine($"Usuario '{usuario}' desbloqueado automáticamente");
                    return false;
                }

                return true;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error verificando bloqueo de usuario: {ex.Message}");
                return true; // Por seguridad, bloquear en caso de error
            }
        }

        /// <summary>
        /// Registra acceso exitoso
        /// </summary>
        private void registrar_acceso_exitoso(string usuario)
        {
            try
            {
                if (!string.IsNullOrWhiteSpace(usuario))
                {
                    System.Diagnostics.Debug.WriteLine(
                        $"✓ Acceso permitido para usuario '{usuario}' en {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error registrando acceso exitoso: {ex.Message}");
            }
        }

        /// <summary>
        /// Registra acceso denegado
        /// </summary>
        protected void denegar_acceso(string motivo = "")
        {
            try
            {
                string mensaje = $"✗ Acceso denegado en {DateTime.Now:yyyy-MM-dd HH:mm:ss}";
                if (!string.IsNullOrWhiteSpace(motivo))
                    mensaje += $". Motivo: {motivo}";

                System.Diagnostics.Debug.WriteLine(mensaje);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error registrando acceso denegado: {ex.Message}");
            }
        }

        /// <summary>
        /// Obtiene información sobre los puntos de corte de este aspecto
        /// </summary>
        public string definir_puntos()
        {
            return "Pointcut: gestionar_reserva() | procesar_factura()";
        }

        /// <summary>
        /// Obtiene el número de intentos fallidos de un usuario
        /// </summary>
        public int obtener_intentos_fallidos(string usuario)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(usuario))
                    throw new ArgumentException("El usuario no puede estar vacío", nameof(usuario));

                return intentos_fallidos.ContainsKey(usuario) ? intentos_fallidos[usuario] : 0;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error obteniendo intentos fallidos: {ex.Message}");
                return -1;
            }
        }

        /// <summary>
        /// Desbloquea manualmente un usuario bloqueado
        /// </summary>
        public bool desbloquear_usuario(string usuario)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(usuario))
                    throw new ArgumentException("El usuario no puede estar vacío", nameof(usuario));

                if (!usuarios_bloqueados.ContainsKey(usuario))
                {
                    System.Diagnostics.Debug.WriteLine($"Usuario '{usuario}' no está bloqueado");
                    return false;
                }

                usuarios_bloqueados.Remove(usuario);
                if (intentos_fallidos.ContainsKey(usuario))
                    intentos_fallidos[usuario] = 0;

                System.Diagnostics.Debug.WriteLine($"Usuario '{usuario}' desbloqueado manualmente por administrador");
                return true;
            }
            catch (ArgumentException ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error: {ex.Message}");
                throw;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error desbloqueando usuario: {ex.Message}");
                return false;
            }
        }

        /// <summary>
        /// Limpia intentos fallidos y desbloqueos
        /// </summary>
        public void reiniciar_estadisticas()
        {
            try
            {
                intentos_fallidos.Clear();
                usuarios_bloqueados.Clear();
                System.Diagnostics.Debug.WriteLine("Estadísticas de autenticación reiniciadas");
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error reiniciando estadísticas: {ex.Message}");
            }
        }
    }
}
