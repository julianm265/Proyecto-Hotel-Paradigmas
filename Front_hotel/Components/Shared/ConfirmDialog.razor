@using MudBlazor

<MudPaper Class="card">
    <MudStack Spacing="2">
        @ChildContent
        <MudStack Direction="Row" Spacing="1">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">Confirmar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancelar</MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    /// <summary>
    /// Emite eventos de confirmación/cancelación para acciones críticas.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
