@inject NotificationService Notifications

<div class="card">
    <div class="card-header">
        <div>
            <h3>Notificaciones</h3>
            <div class="stat-label">Eventos recientes</div>
        </div>
        <span class="badge">@items.Length</span>
    </div>
    <div class="list-stack">
        @if (items.Length == 0)
        {
            <div class="soft-panel">Sin eventos aún.</div>
        }
        else
        {
            @foreach (var item in items)
            {
                <div class="soft-panel @item.Tone">
                    <strong>@item.Message</strong>
                    <div class="stat-label">@item.Timestamp:HH:mm</div>
                </div>
            }
        }
    </div>
</div>

@code {
    private NotificationEntry[] items = Array.Empty<NotificationEntry>();

    protected override void OnInitialized()
    {
        items = Notifications.GetAll();
        Notifications.OnChanged += HandleChanged;
    }

    private void HandleChanged()
    {
        items = Notifications.GetAll();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Notifications.OnChanged -= HandleChanged;
    }
}
