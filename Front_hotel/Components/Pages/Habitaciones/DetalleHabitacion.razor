@page "/habitaciones/detalle/{NumHab}"
@using System.Reflection
@using biblioteca_hotel.Modelos.Camas
@inject HabitacionService HabitacionService
@inject ISnackbar Snackbar

<PageTitle>Detalle Habitación</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Detalle de habitación N.° @NumHab</h2>
        <p class="page-subtitle">Información técnica y detalles de la habitación.</p>
    </div>
</div>

@if (habitacion is null)
{
    <MudAlert Severity="Severity.Warning">Habitación no encontrada.</MudAlert>
}
else
{
    <MudPaper Class="card p-4">
        <MudGrid>
            <!-- Info Panel -->
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">Información General</MudText>
                <div style="display:flex; flex-direction:column; gap:.5rem;">
                    <div><strong>Tipo:</strong> @habitacion.GetType().Name</div>
                    <div><strong>Número:</strong> <span class="mono">@habitacion.GetNumHab()</span></div>
                    <div><strong>Costo por noche:</strong> <span class="mono kpi-gold">@habitacion.GetCostoNoche().ToString("C0", _col)</span></div>
                    
                    @if (habitacion.GetCamas().Any())
                    {
                        <div class="mt-2">
                            <strong>Camas:</strong>
                            <div style="display:flex; flex-wrap:wrap; gap:.5rem; margin-top: .5rem;">
                                @foreach (var c in habitacion.GetCamas())
                                {
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">🛏️ @c.GetType().Name</MudChip>
                                }
                            </div>
                        </div>
                    }

                    @if (habitacion is biblioteca_hotel.Interfaces.Isurtidor)
                    {
                        <div class="mt-2"><MudChip T="string" Color="Color.Secondary" Size="Size.Small">🍸 Soporta Minibar</MudChip></div>
                    }
                </div>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    /// <summary>
    /// Usa HabitacionService para obtener detalle y costo de estancia.
    /// </summary>
    [Parameter] public string NumHab { get; set; } = string.Empty;
    private Habitacion? habitacion;
    private static readonly System.Globalization.CultureInfo _col = new("es-CO");

    protected override void OnInitialized()
    {
        habitacion = HabitacionService.BuscarPornumero(NumHab);
    }
}
