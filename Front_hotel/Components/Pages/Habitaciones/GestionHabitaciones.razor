@page "/habitaciones/gestion"
@inject HabitacionService HabitacionService
@inject biblioteca_hotel.Aspectos.Validador Validador
@inject ISnackbar Snackbar

<PageTitle>Gestión de Habitaciones — Hotel Obsidian</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Habitaciones</h2>
        <p class="page-subtitle">Crear y administrar las habitaciones del hotel.</p>
    </div>
</div>

<MudGrid GutterSize="3">
    <!-- Formulario de creación -->
    <MudItem xs="12" md="5">
        <div class="glass-card">
            <div class="glass-card-inner">
                <div class="section-eyebrow">Nueva Habitación</div>

                <!-- Número de habitación -->
                <MudTextField Label="Número de Habitación"
                              @bind-Value="_numHab"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="obs-select mb-field"
                              Placeholder="Ej: 101, 202, 305"
                              HelperText="@(_numDuplicado ? "⚠️ Ese número ya existe." : "Identificador único de la habitación")"
                              Error="@_numDuplicado"
                              Immediate="true"
                              @oninput="ValidarNumero"
                              id="hab-numero" />

                <!-- Piso -->
                <MudNumericField Label="Piso"
                                 @bind-Value="_piso"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="obs-select mb-field"
                                 Min="1" Max="50"
                                 id="hab-piso" />

                <!-- Tipo de habitación -->
                <div class="field-label-small">Tipo de Habitación</div>
                <div class="tipo-cards mb-field">
                    <div class="tipo-card @(_tipoSeleccionado == TipoHab.Sencilla ? "tipo-card-selected" : "")"
                         @onclick="@(() => _tipoSeleccionado = TipoHab.Sencilla)"
                         id="tipo-sencilla">
                        <span class="tipo-icon">🛏️</span>
                        <div class="tipo-info">
                            <div class="tipo-nombre">Sencilla</div>
                            <div class="tipo-desc">Sin minibar</div>
                        </div>
                        @if (_tipoSeleccionado == TipoHab.Sencilla) { <div class="tipo-check">✓</div> }
                    </div>
                    <div class="tipo-card @(_tipoSeleccionado == TipoHab.Ejecutiva ? "tipo-card-selected" : "")"
                         @onclick="@(() => _tipoSeleccionado = TipoHab.Ejecutiva)"
                         id="tipo-ejecutiva">
                        <span class="tipo-icon">👔</span>
                        <div class="tipo-info">
                            <div class="tipo-nombre">Ejecutiva</div>
                            <div class="tipo-desc">Con minibar Ejecutivo</div>
                        </div>
                        @if (_tipoSeleccionado == TipoHab.Ejecutiva) { <div class="tipo-check">✓</div> }
                    </div>
                    <div class="tipo-card @(_tipoSeleccionado == TipoHab.Suite ? "tipo-card-selected" : "")"
                         @onclick="@(() => _tipoSeleccionado = TipoHab.Suite)"
                         id="tipo-suite">
                        <span class="tipo-icon">👑</span>
                        <div class="tipo-info">
                            <div class="tipo-nombre">Suite</div>
                            <div class="tipo-desc">Con minibar Suite</div>
                        </div>
                        @if (_tipoSeleccionado == TipoHab.Suite) { <div class="tipo-check">✓</div> }
                    </div>
                </div>

                <!-- Precio base -->
                <MudNumericField Label="Precio Base por Noche (COP)"
                                 @bind-Value="_precioBase"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="obs-select mb-field"
                                 Min="0m"
                                 Format="N0"
                                 id="hab-precio" />

                <!-- Tipo de cama -->
                <MudSelect T="string" Label="Tipo de Cama"
                           @bind-Value="_tipoCama"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="obs-select mb-field">
                    <MudSelectItem Value="@("sencilla")">Sencilla</MudSelectItem>
                    <MudSelectItem Value="@("doble")">Doble</MudSelectItem>
                    <MudSelectItem Value="@("semidoble")">Semidoble</MudSelectItem>
                    <MudSelectItem Value="@("queen")">Queen</MudSelectItem>
                    <MudSelectItem Value="@("king")">King</MudSelectItem>
                </MudSelect>

                @if (_errorMsg != null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-field" Dense="true">@_errorMsg</MudAlert>
                }

                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           OnClick="CrearHabitacion"
                           Class="obs-button-glow"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@(!PuedeCrear)"
                           FullWidth="true"
                           aria-label="Crear habitación">
                    Crear Habitación
                </MudButton>
            </div>
        </div>
    </MudItem>

    <!-- Lista de habitaciones -->
    <MudItem xs="12" md="7">
        <div class="glass-card">
            <div class="glass-card-inner">
                <div class="section-eyebrow">Habitaciones Registradas (@_habitaciones.Length)</div>

                @if (_habitaciones.Length == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">🏨</span>
                        <p>No hay habitaciones registradas aún.</p>
                    </div>
                }
                else
                {
                    <div class="hab-list">
                        @foreach (var h in _habitaciones)
                        {
                            var esMinibar = h is biblioteca_hotel.Interfaces.Isurtidor;
                            var icono = h switch
                            {
                                Suite _    => "👑",
                                Ejecutiva _ => "👔",
                                _          => "🛏️"
                            };
                            <div class="hab-row">
                                <div class="hab-icon">@icono</div>
                                <div class="hab-body">
                                    <div class="hab-nombre">@h.GetType().Name</div>
                                    <div class="hab-meta">
                                        N.° <span class="mono">@h.GetNumHab()</span>
                                        @if (esMinibar)
                                        {
                                            <span class="hab-badge badge-minibar">🍸 Minibar</span>
                                        }
                                    </div>
                                </div>
                                <div class="hab-precio font-mono">@h.GetCostoNoche().ToString("C0", _col)/noche</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </MudItem>
</MudGrid>

@code {
    /// <summary>
    /// CRUD de Habitaciones: crea Sencilla, Ejecutiva o Suite.
    /// Validación: no permite números duplicados (Validador AOP).
    /// Snackbar: confirmación o error en cada acción.
    /// </summary>

    private enum TipoHab { Sencilla, Ejecutiva, Suite }

    private Habitacion[] _habitaciones = Array.Empty<Habitacion>();
    private string _numHab    = string.Empty;
    private int    _piso      = 1;
    private decimal _precioBase = biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.costo_noche_hab_sencilla;
    private string _tipoCama  = "queen";
    private TipoHab _tipoSeleccionado = TipoHab.Sencilla;
    private bool   _numDuplicado;
    private string? _errorMsg;

    private static readonly System.Globalization.CultureInfo _col = new("es-CO");

    private bool PuedeCrear =>
        !string.IsNullOrWhiteSpace(_numHab) &&
        !_numDuplicado &&
        _precioBase > 0 &&
        !string.IsNullOrEmpty(_tipoCama);

    protected override void OnInitialized()
    {
        RefrescarLista();
    }

    private void ValidarNumero(ChangeEventArgs e)
    {
        _numHab = e.Value?.ToString() ?? string.Empty;
        _numDuplicado = HabitacionService.BuscarPornumero(_numHab) != null;
    }

    private void RefrescarLista()
    {
        _habitaciones = HabitacionService.ObtenerTodos();
    }

    private void CrearHabitacion()
    {
        _errorMsg = null;

        // Validación: número duplicado
        if (_numDuplicado)
        {
            _errorMsg = $"Ya existe una habitación con el número {_numHab}.";
            Snackbar.Add(_errorMsg, Severity.Error);
            return;
        }
        if (string.IsNullOrWhiteSpace(_numHab))
        {
            _errorMsg = "El número de habitación es requerido.";
            Snackbar.Add(_errorMsg, Severity.Warning);
            return;
        }

        try
        {
            Habitacion nueva = _tipoSeleccionado switch
            {
                TipoHab.Ejecutiva => new Ejecutiva(_precioBase, _tipoCama, _numHab),
                TipoHab.Suite     => new Suite(_precioBase, _tipoCama, _numHab),
                _                 => new Sencilla(_precioBase, _tipoCama, _piso)
            };

            // Sobrescribir num_hab con el ingresado por el usuario via reflexión
            // (num_hab es protected, lo asignamos a través del constructor solo para Sencilla;
            //  para Ejecutiva/Suite usamos el campo protegido directamente vía subclase)
            // Dado que num_hab es protected, creamos las subclases con el número ya dado.
            // Usamos la factory corriente de cada subclase y luego persiste.

            HabitacionService.Agregar(nueva);
            Validador.Advice_ValidarYPersistir(nueva);

            Snackbar.Add($"✅ Habitación {_tipoSeleccionado} N.°{nueva.GetNumHab()} creada correctamente.", Severity.Success);

            // Reset form
            _numHab      = string.Empty;
            _piso        = 1;
            _precioBase  = biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.costo_noche_hab_sencilla;
            _tipoCama    = "queen";
            _tipoSeleccionado = TipoHab.Sencilla;
            _numDuplicado = false;

            RefrescarLista();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
            Snackbar.Add($"✗ Error: {ex.Message}", Severity.Error);
        }
    }
}

<style>
    .mb-field { margin-bottom: .85rem !important; }
    .field-label-small {
        font-size: .78rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: .08em; color: var(--silver); margin-bottom: .45rem;
    }

    /* ── Tipo Cards ── */
    .tipo-cards { display: flex; flex-direction: column; gap: .45rem; }
    .tipo-card {
        display: flex; align-items: center; gap: .85rem;
        padding: .75rem .9rem; border-radius: var(--radius-sm);
        background: rgba(8,10,15,0.5); border: 1px solid var(--border);
        cursor: pointer; transition: all 180ms;
    }
    .tipo-card:hover { border-color: var(--gold-dim); background: rgba(196,160,80,0.05); }
    .tipo-card-selected {
        border-color: var(--gold) !important;
        background: rgba(196,160,80,0.1) !important;
        box-shadow: 0 0 10px rgba(196,160,80,0.15);
    }
    .tipo-icon { font-size: 1.35rem; flex-shrink: 0; }
    .tipo-info { flex: 1; }
    .tipo-nombre { font-weight: 600; color: var(--platinum); font-size: .88rem; }
    .tipo-desc   { font-size: .72rem; color: var(--silver); margin-top: .1rem; }
    .tipo-check  {
        width: 20px; height: 20px; border-radius: 50%;
        background: var(--gold); color: #000; font-size: .72rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center; flex-shrink:0;
    }

    /* ── Hab List ── */
    .hab-list { display: flex; flex-direction: column; gap: .5rem; }
    .hab-row {
        display: flex; align-items: center; gap: 1rem;
        padding: .8rem 1rem; border-radius: var(--radius-sm);
        background: rgba(8,10,15,0.4); border: 1px solid var(--border);
        transition: border-color 180ms;
    }
    .hab-row:hover { border-color: var(--gold-dim); }
    .hab-icon { font-size: 1.4rem; flex-shrink:0; }
    .hab-body { flex: 1; }
    .hab-nombre { font-weight: 600; color: var(--platinum); font-size: .9rem; }
    .hab-meta { font-size: .76rem; color: var(--silver); display: flex; align-items: center; gap: .4rem; margin-top: .15rem; }
    .hab-badge {
        display: inline-block; font-size: .68rem; padding: .1rem .45rem;
        border-radius: 999px;
    }
    .badge-minibar { background: rgba(139,92,246,0.15); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3); }
    .hab-precio { color: var(--gold); font-size: .85rem; white-space: nowrap; }
</style>
