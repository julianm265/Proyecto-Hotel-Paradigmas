@page "/habitaciones/minibar/{Index:int}"
@inject HabitacionService HabitacionService
@inject ISnackbar Snackbar

<PageTitle>Asignar Minibar</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Asignar minibar</h2>
        <p class="page-subtitle">Configura el minibar según tipo de habitación.</p>
    </div>
</div>

@if (habitacion is null)
{
    <MudAlert Severity="Severity.Warning">Habitación no encontrada.</MudAlert>
}
else if (habitacion is not biblioteca_hotel.Interfaces.Isurtidor surtidor)
{
    <MudAlert Severity="Severity.Warning">Esta habitación no tiene minibar.</MudAlert>
}
else
{
    <MudPaper Class="card">
        <MudStack Spacing="2">
            <MudSelect T="TipoMinibar" Label="Tipo minibar" @bind-Value="tipo" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem Value="TipoMinibar.Ejecutivo">Ejecutivo</MudSelectItem>
                <MudSelectItem Value="TipoMinibar.Suite">Suite</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => LlenarMinibar(surtidor)">
                Llenar minibar
            </MudButton>
            <MudDivider />
            <MudText Typo="Typo.subtitle2">Precios vigentes</MudText>
            <MudDataGrid Items="productos" Dense="true">
                <Columns>
                    <PropertyColumn Property="p => p.Nombre" Title="Producto" />
                    <PropertyColumn Property="p => p.Precio" Title="Precio" />
                </Columns>
            </MudDataGrid>
        </MudStack>
    </MudPaper>
}

@code {
    /// <summary>
    /// Usa HabitacionService e ISurtidor para llenar minibar y mostrar precios.
    /// </summary>
    [Parameter] public int Index { get; set; }
    private Habitacion? habitacion;
    private TipoMinibar tipo = TipoMinibar.Ejecutivo;
    private List<ProductoMinibar> productos = new();

    protected override void OnInitialized()
    {
        var habitaciones = HabitacionService.ObtenerTodos();
        habitacion = Index >= 0 && Index < habitaciones.Length ? habitaciones[Index] : null;
        productos = new List<ProductoMinibar>
        {
            new("Licor", ReglasNegocioHabitaciones.precio_licor),
            new("Vino", ReglasNegocioHabitaciones.precio_vino),
            new("Kit aseo", ReglasNegocioHabitaciones.precio_kit_aseo),
            new("Agua", ReglasNegocioHabitaciones.precio_agua),
            new("Gaseosa", ReglasNegocioHabitaciones.precio_gaseosa),
            new("Bata", ReglasNegocioHabitaciones.precio_bata)
        };
    }

    private void LlenarMinibar(biblioteca_hotel.Interfaces.Isurtidor surtidor)
    {
        surtidor.LLenar(tipo);
        Snackbar.Add("Minibar actualizado.", Severity.Success);
    }

    private record ProductoMinibar(string Nombre, decimal Precio);
}
