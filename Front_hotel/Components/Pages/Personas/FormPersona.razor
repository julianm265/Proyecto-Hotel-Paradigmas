@page "/personas/nueva"
@inject PersonaService PersonaService
@inject ISnackbar Snackbar
@inject biblioteca_hotel.Aspectos.Validador Validador

<PageTitle>Nueva persona</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Nueva persona</h2>
        <p class="page-subtitle">Registro con validación de documento y teléfono.</p>
    </div>
</div>

<MudPaper Class="card">
    <MudStack Spacing="2">
        <MudSelect T="string" Label="Tipo persona" @bind-Value="tipoPersona" Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem Value="@("Cliente")">Cliente</MudSelectItem>
            <MudSelectItem Value="@("Huesped")">Huésped</MudSelectItem>
        </MudSelect>
        <MudTextField Label="Nombre" 
                      @bind-Value="nombre" 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense"
                      HelperText="Solo letras y espacios, máximo 100 caracteres" />
        <MudSelect T="string" Label="Tipo ID" @bind-Value="tipoId" Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem Value="@("DNI")">DNI</MudSelectItem>
            <MudSelectItem Value="@("PASAPORTE")">Pasaporte</MudSelectItem>
            <MudSelectItem Value="@("CE")">Carnet de Extranjería</MudSelectItem>
            <MudSelectItem Value="@("NIT")">NIT</MudSelectItem>
        </MudSelect>
        <MudTextField Label="Documento" 
                      @bind-Value="documento" 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense"
                      HelperText="@ObtenerMensajeDocumento()" />
        <MudTextField Label="Teléfono" 
                      @bind-Value="telefono" 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense"
                      InputType="InputType.Number"
                      HelperText="Mínimo 10 dígitos. Ej: 3015234567" />
        @if (tipoPersona == "Cliente")
        {
            <MudAlert Severity="Severity.Info" Class="mt-2">El código de cliente y el descuento semanal se generarán automáticamente.</MudAlert>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Registrar">Registrar</MudButton>
    </MudStack>
</MudPaper>

@code {
    /// <summary>
    /// Usa PersonaService y Validador para registrar personas con reglas de negocio.
    /// </summary>
    private string tipoPersona = "Cliente";
    private string nombre = string.Empty;
    private string tipoId = "DNI";
    private string documento = string.Empty;
    private string telefono = string.Empty;

    private string ObtenerMensajeDocumento()
    {
        return tipoId switch
        {
            "DNI" or "NIT" => "Solo números. Entre 5 y 20 caracteres.",
            "PASAPORTE" or "CE" => "Números y letras. Entre 5 y 20 caracteres.",
            _ => "Entre 5 y 20 caracteres."
        };
    }

    private void Registrar()
    {
        try
        {
            Persona persona = tipoPersona == "Cliente"
                ? new Cliente(nombre, tipoId, documento, telefono)
                : new Huesped(nombre, tipoId, documento, telefono);

            PersonaService.Agregar(persona);
            Validador.Advice_ValidarYPersistir(persona);
            if (persona is Cliente c)
            {
                Snackbar.Add($"Cliente registrado. Código: {c.GetCodigo()}, Descuento: {c.GetDescuento():P}", Severity.Success);
            }
            else
            {
                Snackbar.Add("Persona registrada.", Severity.Success);
            }
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al registrar: {ex.Message}", Severity.Error);
        }
    }
}
