@page "/servicios"

<PageTitle>Servicios</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Servicios hoteleros</h2>
        <p class="page-subtitle">Restaurante, lavandería y minibar.</p>
    </div>
</div>

<MudGrid GutterSize="3">
    <MudItem xs="12" md="4">
        <MudPaper Class="card">
            <MudText Typo="Typo.h6">Restaurante</MudText>
            <MudText>Gestiona consumos de carta.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/servicios/restaurante">Abrir</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="card">
            <MudText Typo="Typo.h6">Lavandería</MudText>
            <MudText>Servicios por prenda y planchado.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/servicios/lavanderia">Abrir</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="card">
            <MudText Typo="Typo.h6">Minibar</MudText>
            <MudText>Consumos en habitación.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/servicios/minibar">Abrir</MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>
