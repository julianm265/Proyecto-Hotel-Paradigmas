@page "/configuracion"

<PageTitle>Reglas de Negocio — Hotel Obsidian</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Reglas de Negocio</h2>
        <p class="page-subtitle">Parámetros del sistema — solo lectura.</p>
    </div>
</div>

<MudGrid GutterSize="3">
    <!-- Habitaciones -->
    <MudItem xs="12" md="4">
        <div class="glass-card">
            <div class="glass-card-inner">
                <div class="rules-header">
                    <span class="rules-icon">🔑</span>
                    <div class="section-eyebrow" style="margin-bottom:0;">Habitaciones</div>
                    <span class="lock-icon" title="Solo lectura" aria-label="Solo lectura">🔒</span>
                </div>
                <div class="rules-list">
                    <div class="rule-row">
                        <span class="rule-label">Hab. Sencilla / noche</span>
                        <span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.costo_noche_hab_sencilla.ToString("C0", _col)</span>
                    </div>
                    <div class="rule-row">
                        <span class="rule-label">Hab. Ejecutiva / noche</span>
                        <span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.costo_noche_hab_ejecutiva.ToString("C0", _col)</span>
                    </div>
                    <div class="rule-row">
                        <span class="rule-label">Suite / noche</span>
                        <span class="rule-value font-mono kpi-gold">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.costo_noche_suite.ToString("C0", _col)</span>
                    </div>
                </div>
                <div class="section-eyebrow mt-4" style="font-size:.65rem;">Minibar</div>
                <div class="rules-list">
                    <div class="rule-row"><span class="rule-label">Licor</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_licor.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Vino</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_vino.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Agua</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_agua.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Gaseosa</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_gaseosa.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Kit aseo</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_kit_aseo.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Bata de baño</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioHabitaciones.precio_bata.ToString("C0", _col)</span></div>
                </div>
            </div>
        </div>
    </MudItem>

    <!-- Servicios -->
    <MudItem xs="12" md="4">
        <div class="glass-card">
            <div class="glass-card-inner">
                <div class="rules-header">
                    <span class="rules-icon">🍽️</span>
                    <div class="section-eyebrow" style="margin-bottom:0;">Servicios</div>
                    <span class="lock-icon" aria-label="Solo lectura">🔒</span>
                </div>
                <div class="rules-list">
                    <div class="rule-row"><span class="rule-label">Desayuno</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.Costo_desayuno.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Almuerzo</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.Costo_almuerzo.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Cena</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.costo_cena.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Serv. a habitación</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.recargo_serv_habitacion.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Lavado / prenda</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.Precio_por_prenda_lavand.ToString("C0", _col)</span></div>
                    <div class="rule-row"><span class="rule-label">Planchado / prenda</span><span class="rule-value font-mono">@biblioteca_hotel.Utilidades.ReglasNegocioServicios.precio_planchada.ToString("C0", _col)</span></div>
                </div>
            </div>
        </div>
    </MudItem>

    <!-- Fiscales -->
    <MudItem xs="12" md="4">
        <div class="glass-card">
            <div class="glass-card-inner">
                <div class="rules-header">
                    <span class="rules-icon">⚖️</span>
                    <div class="section-eyebrow" style="margin-bottom:0;">Fiscales y Validación</div>
                    <span class="lock-icon" aria-label="Solo lectura">🔒</span>
                </div>
                <div class="rules-list">
                    <div class="rule-row">
                        <span class="rule-label">IVA (colombiano)</span>
                        <span class="rule-value font-mono kpi-emerald">@((biblioteca_hotel.Utilidades.Regla_negocio.valor_IVA * 100).ToString("F0"))%</span>
                    </div>
                    <div class="rule-row">
                        <span class="rule-label">Seguro hotelero</span>
                        <span class="rule-value font-mono">@((biblioteca_hotel.Utilidades.Regla_negocio.seguro_hotelero * 100).ToString("F0"))%</span>
                    </div>
                    <div class="rule-row">
                        <span class="rule-label">Penalización cancelación</span>
                        <span class="rule-value font-mono kpi-ruby">10% noche sencilla</span>
                    </div>
                </div>
                <div class="section-eyebrow mt-4" style="font-size:.65rem;">Regex de Validación</div>
                <div class="rules-list">
                    <div class="rule-row">
                        <span class="rule-label">Regex Documento</span>
                        <span class="rule-value font-mono" style="font-size:.72rem;color:var(--sapphire);">@biblioteca_hotel.Utilidades.Regla_negocio.regex_id</span>
                    </div>
                    <div class="rule-row">
                        <span class="rule-label">Regex Teléfono</span>
                        <span class="rule-value font-mono" style="font-size:.72rem;color:var(--sapphire);">@biblioteca_hotel.Utilidades.Regla_negocio.regex_telefono</span>
                    </div>
                </div>
                <div class="section-eyebrow mt-4" style="font-size:.65rem;">Pointcuts AOP</div>
                <div class="rules-list">
                    <div class="rule-row"><span class="rule-label font-mono" style="font-size:.72rem;">Validador</span><span class="rule-value" style="font-size:.7rem;color:var(--amethyst);">guardar(Reserva|Factura|Persona)</span></div>
                    <div class="rule-row"><span class="rule-label font-mono" style="font-size:.72rem;">Autenticador</span><span class="rule-value" style="font-size:.7rem;color:var(--amethyst);">acceder(Recepcion|Oficina)</span></div>
                </div>
            </div>
        </div>
    </MudItem>
</MudGrid>

@code {
    private static readonly System.Globalization.CultureInfo _col = new("es-CO");
}

<style>
    .rules-header { display:flex; align-items:center; gap:.6rem; margin-bottom:1rem; }
    .rules-icon   { font-size:1.2rem; }
    .lock-icon    { margin-left:auto; font-size:.9rem; opacity:.6; cursor:default; }
    .rules-list   { display:flex; flex-direction:column; gap:.1rem; }
    .rule-row     { display:flex; justify-content:space-between; align-items:center; padding:.5rem 0; border-bottom:1px solid rgba(30,37,53,0.5); }
    .rule-row:last-child { border-bottom:none; }
    .rule-label   { font-size:.8rem; color:var(--silver); }
    .rule-value   { font-size:.82rem; color:var(--platinum); font-weight:500; }
    .kpi-ruby     { color:var(--ruby); }
    .mt-4         { margin-top:1rem !important; }
</style>
