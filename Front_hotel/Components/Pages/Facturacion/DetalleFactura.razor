@page "/facturacion/detalle/{Codigo}"
@inject FacturaService FacturaService

<PageTitle>Detalle factura</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Detalle de factura</h2>
        <p class="page-subtitle">Productos, servicios e impuestos.</p>
    </div>
</div>

@if (factura is null)
{
    <MudAlert Severity="Severity.Warning">Factura no encontrada.</MudAlert>
}
else
{
    <MudPaper Class="card">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">@factura.GetPersona().GetNombre()</MudText>
            <MudDivider />
            <MudText Typo="Typo.subtitle2">Productos</MudText>
            <MudDataGrid Items="productos" Dense="true">
                <Columns>
                    <PropertyColumn Property="p => p.Nombre" Title="Producto" />
                    <PropertyColumn Property="p => p.Codigo" Title="Código" />
                    <PropertyColumn Property="p => p.Costo" Title="Costo" />
                </Columns>
            </MudDataGrid>
            <MudDivider />
            <MudText Typo="Typo.subtitle2">Servicios</MudText>
            <MudDataGrid Items="servicios" Dense="true">
                <Columns>
                    <PropertyColumn Property="s => s.Descripcion" Title="Servicio" />
                    <PropertyColumn Property="s => s.Costo" Title="Costo" />
                </Columns>
            </MudDataGrid>
            <MudDivider />
            <MudText>Subtotal: @factura.CalcularSubtotal()</MudText>
            <MudText>Impuestos: @factura.CalcularImpuestos(true)</MudText>
            <MudText>Total: @factura.calcularTotal()</MudText>
        </MudStack>
    </MudPaper>
}

@code {
    /// <summary>
    /// Usa FacturaService e IProductoMinibar.Mostrar_cod para el detalle de productos.
    /// </summary>
    [Parameter] public string Codigo { get; set; } = string.Empty;
    private Factura? factura;
    private List<ItemProducto> productos = new();
    private List<ItemServicio> servicios = new();

    protected override void OnInitialized()
    {
        factura = FacturaService.BuscarPorCodigo(Codigo);
        if (factura is null)
            return;

        productos = factura.GetProductos().Select(p => new ItemProducto(
            p switch
            {
                biblioteca_hotel.Modelos.Productos.ProductoRestaurante pr => pr.GetNombreProducto(),
                biblioteca_hotel.Modelos.Productos.ConsumoMinibar cm => cm.GetNombreProducto(),
                _ => p.GetType().Name
            },
            p is IProductoMinibar minibar ? minibar.Mostrar_cod(p) : p.GetHashCode().ToString(),
            p.GetCosto()
        )).ToList();

        servicios = factura.GetServicios().Select(s => new ItemServicio(
            string.IsNullOrWhiteSpace(s.GetDescripcion()) ? s.GetType().Name : s.GetDescripcion(),
            s.GetCosto()
        )).ToList();
    }

    private record ItemProducto(string Nombre, string Codigo, decimal Costo);
    private record ItemServicio(string Descripcion, decimal Costo);
}
